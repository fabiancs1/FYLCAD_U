/* ═══════════════════════════════════════════════
   FYLCAD — Animaciones del Dashboard
   Agregar al final de css/dashboard.css
   o incluir como <link> en dashboard.php
═══════════════════════════════════════════════ */

/* ── Hover mejorado en cards ── */
.bento-card {
    will-change: transform, box-shadow;
}

.bento-card:hover {
    transform: translateY(-3px) !important;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4) !important;
}

/* ── Stat cards: brillo al hacer hover ── */
.card-stat:hover .stat-num {
    color: var(--accent);
    transition: color 0.3s ease;
}

.card-stat:hover .stat-ico {
    transform: scale(1.12) rotate(-4deg);
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
}

.stat-ico {
    transition: transform 0.3s ease;
}

/* ── Número de stats con fuente más expresiva ── */
.stat-num {
    transition: color 0.3s ease;
}

/* ── Animación de entrada para la topbar ── */
@keyframes topbarDown {
    from { opacity: 0; transform: translateY(-100%); }
    to   { opacity: 1; transform: translateY(0); }
}

.topbar {
    animation: topbarDown 0.4s cubic-bezier(.22,1,.36,1) forwards;
}

/* ── Shimmer skeleton (por si quieres usarlo) ── */
@keyframes shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position: 400px 0; }
}

.skeleton {
    background: linear-gradient(90deg, #0c1120 25%, #151d30 50%, #0c1120 75%);
    background-size: 800px 100%;
    animation: shimmer 1.4s infinite;
    border-radius: 8px;
}

/* ── Proyectos recientes: hover con línea izquierda ── */
.proy-row, [class*="proy-item"] {
    transition: background 0.2s, padding-left 0.2s, border-left 0.2s;
    border-left: 2px solid transparent;
}

.proy-row:hover, [class*="proy-item"]:hover {
    background: rgba(0, 229, 192, 0.04) !important;
    border-left-color: var(--accent);
    padding-left: 6px;
}

/* ── Actividad reciente: hover suave ── */
.act-row, [class*="act-item"] {
    transition: background 0.2s ease;
}

.act-row:hover, [class*="act-item"]:hover {
    background: rgba(255, 255, 255, 0.03) !important;
}

/* ── Botones de acción con efecto de pulso al hover ── */
.card-actions a:hover,
.card-actions button:hover {
    animation: btnPulse 0.3s ease;
}

@keyframes btnPulse {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.04); }
    100% { transform: scale(1); }
}
